# =============================================================================
# Viral Reel Automation Pipeline — environment template
# =============================================================================
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# ----- Anthropic (Stage 1 script generation, Stage 6 video DSSCL scoring) ----
ANTHROPIC_API_KEY=sk-ant-...

# ----- Kie.ai (Stage 2 b-roll Kling fallback, Stage 4 BGM via ElevenLabs) ----
KIE_API_KEY=...

# Kling b-roll model. Default text-to-video. Switch to
# "kling-2.6/image-to-video" to use the nano-banana-2 → I2V two-step pipeline.
BROLL_MODEL=kling-2.6/text-to-video

# Optional webhook for Kie.ai async callbacks. Leave blank to use polling.
CALLBACK_URL=

# ----- HeyGen (Stage 3 talking-head avatar) ---------------------------------
HEYGEN_API_KEY=...
HEYGEN_VOICE_ID=...

# Active avatar for the run. Override per-run if you want a different look.
HEYGEN_AVATAR_ID=98ad52735e614741beab2b011da90f99

# Avatar pool (optional — populate from HeyGen avatar library)
HEYGEN_AVATAR_ID_BLACK=
HEYGEN_AVATAR_ID_GREY=
HEYGEN_AVATAR_ID_BLUE=
HEYGEN_AVATAR_ID_WHITE=
HEYGEN_AVATAR_ID_BKSHRT=

# ----- Whisper (Stage 5 captions + section-timestamp sync) ------------------
# "medium" is fast + accurate enough for most runs (~3 min).
# Use "large-v3" for best accuracy on proper nouns (~12-15 min, 1.5GB download).
WHISPER_MODEL=medium

# ----- Nano Banana (infographic mode — scripts/generate_infographic.py) ------
# Google AI Studio API key for Gemini 3.1 Flash Image (Nano Banana 2).
# Get one at https://aistudio.google.com/apikey — no GCP project required.
# Used only when you run the infographic skill, NOT by the main pipeline.
GEMINI_API_KEY=

# ----- Optional integrations ------------------------------------------------
# OPENAI_API_KEY=
# YOUTUBE_API_KEY=
